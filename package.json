    "@tetherget/self-test-core": "file:../packages/self-test-core",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.4.1",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tweetnacl": "^1.0.3",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.8",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.49.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
