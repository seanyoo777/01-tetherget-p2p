hotRollbackPanel.jsx\" \"src/admin/panels/OpsReportHashPanel.jsx\" \"src/admin/panels/OpsWebhookStatusPanel.jsx\" \"src/admin/panels/OpsPermissionAuditPanel.jsx\" \"src/admin/panels/AuditOverviewPanel.jsx\" \"src/admin/panels/AuditP2pOrderMonitorPanel.jsx\" \"src/admin/adminSelfTestModel.js\" \"src/admin/adminSelfTestEngine.js\" \"src/admin/adminTestIds.js\" \"src/admin/adminMemberModel.js\" \"src/admin/panels/AdminSelfTestCenterPanel.jsx\" \"src/membership/**/*.js\" \"src/membership/ui/*.jsx\"",
    "verify:admin-stage": "node server/scripts/verify-admin-stage-consistency.mjs",
    "verify:admin-downline": "node server/scripts/verify-admin-downline-consistency.mjs",
    "verify:referral-engine": "node server/scripts/verify-referral-tree-engine.mjs",
