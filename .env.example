PORT=4000
# Node 버전을 올리거나 낮춘 뒤 ERR_DLOPEN_FAILED / better-sqlite3 이면: npm run rebuild:sqlite
JWT_SECRET=replace-with-strong-secret
# NODE_ENV=production 일 때 위 값이 코드 기본값과 같으면 서버가 시작되지 않습니다.

# P2P 매칭 후 송금 신청·송금 확인(버튼)까지 허용 시간(분). 초과 시 matched 주문 자동 취소.
P2P_MATCH_SLA_MINUTES=30

# 통합 플랫폼 식별 (여러 제품/레포가 한 게이트웨이로 모일 때 동일 패턴 사용)
PLATFORM_CODE=tetherget
SERVICE_LINE=p2p
VITE_PLATFORM_CODE=tetherget
VITE_SERVICE_LINE=p2p
# Local: 프론트는 npm run dev → http://localhost:5171 (01-TetherGet-P2P vite 고정; 02번은 보통 5173).
# API: 이 레포 server/index.js 가 아닌 다른 프로세스가 :4000 을 쓰면 GET /api/health 로 확인하세요.
#   이 레포 API는 {"ok":true,"service":"tetherget-mvp-api"} 형태입니다.
#   확인: npm run verify:api-origin  (.env 의 VITE_API_BASE 또는 기본 4000 대상)
# Vercel Preview/Production 빌드에서는 반드시 공개 API Origin으로 설정 (예: https://api.example.com).
VITE_API_BASE=http://localhost:4000

# 시세: 내장 id 또는 registerPriceFeedProvider 로 등록한 커스텀 id (DB 미지정 시만 적용)
# 관리자 화면 「본사 운영 설정」에서 시세 출처를 지정하면 platform_settings.market.price_feed 가 우선합니다.
# 내장: coinmarketcap | coingecko | upbit | static
# 로컬(키 없음): coingecko 권장. 운영에서 CMC 쓰려면 키 발급 후 아래 주석 해제.
# https://pro.coinmarketcap.com/signup — PROVIDER 비우고 PRICE_FEED_CMC_API_KEY 만 넣어도 자동 coinmarketcap
PRICE_FEED_PROVIDER=coingecko
# PRICE_FEED_PROVIDER=coinmarketcap
PRICE_FEED_CMC_API_KEY=
PRICE_FEED_CMC_SYMBOLS=BTC,ETH,SOL,USDT
PRICE_FEED_CMC_CONVERT=KRW,USD,VND,JPY
PRICE_FEED_COINGECKO_IDS=bitcoin,ethereum,solana,tether
PRICE_FEED_COINGECKO_VS=krw,usd,vnd,jpy
PRICE_FEED_UPBIT_MARKETS=KRW-BTC,KRW-ETH,KRW-USDT,KRW-SOL
# 서버 메모리 캐시 TTL(ms)
PRICE_FEED_CACHE_MS=45000

GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# future postgres migration
DATABASE_URL=postgres://tetherget:tetherget_dev_password@localhost:5432/tetherget

# future redis integration
REDIS_URL=redis://localhost:6379

# KYC field encryption key (set strong random secret in production)
KYC_ENCRYPTION_KEY=replace-with-strong-kyc-key
